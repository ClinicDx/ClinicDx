# =============================================================================
# ClinicDx V1 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values before first launch:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All values here are safe defaults suitable for a local development run.
# =============================================================================

# -----------------------------------------------------------------------------
# HuggingFace — used by model and KB containers to auto-download artifacts
# -----------------------------------------------------------------------------
# Your HF token (read access is sufficient, only needed if repo is gated)
HF_TOKEN=

# HuggingFace repo containing the GGUF model artifacts
HF_MODEL_REPO=ClinicDx/medgemma-cds-v1-gguf

# HuggingFace repo containing the KB index artifacts
HF_KB_REPO=ClinicDx/knowledge-base-v2

# -----------------------------------------------------------------------------
# Model server (llama-server)
# -----------------------------------------------------------------------------
# Internal port that llama-server binds to inside its container
MODEL_PORT=8180

# Number of GPU layers to offload (999 = all layers on GPU, 0 = CPU only)
# This value is overridden to 0 in docker-compose.cpu.yml
N_GPU_LAYERS=999

# Context window size (tokens)
MODEL_CTX=8192

# Parallel inference slots (increase for concurrent requests)
MODEL_PARALLEL=4

# Number of CPU threads (used only in CPU mode)
MODEL_THREADS=8

# -----------------------------------------------------------------------------
# Knowledge Base daemon
# -----------------------------------------------------------------------------
# Port the KB daemon listens on inside its container (always 4276)
KB_PORT=4276

# Search mode: rrf (default, best quality) | lex | sem
KB_SEARCH_MODE=rrf

# Default number of results returned per query
KB_K=5

# Default snippet length in characters
KB_SNIPPET_CHARS=15000

# -----------------------------------------------------------------------------
# Middleware (FastAPI)
# -----------------------------------------------------------------------------
# Internal port that the middleware FastAPI app binds to
MIDDLEWARE_PORT=8080

# Log level for the middleware service
MIDDLEWARE_LOG_LEVEL=INFO

# OpenMRS backend URL (used by scribe_router for FHIR posting)
OPENMRS_URL=http://openmrs:8080/openmrs
OPENMRS_USER=admin
OPENMRS_PASSWORD=Admin123

# -----------------------------------------------------------------------------
# nginx reverse proxy
# -----------------------------------------------------------------------------
# Public HTTPS port (host machine)
NGINX_HTTPS_PORT=443

# Public HTTP port — redirects to HTTPS
NGINX_HTTP_PORT=80

# Path to SSL certificate and key (mounted into nginx container)
# For development you can use a self-signed cert:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout certs/server.key -out certs/server.crt -subj "/CN=localhost"
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Global log level applied to all Python services (DEBUG|INFO|WARN|ERROR)
LOG_LEVEL=INFO
